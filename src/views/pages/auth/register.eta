<!DOCTYPE html>
<html lang="en">
  <%~ include('./partials/head') %>

  <body>
    <!-- LOADING AREA START ===== -->
    <div class="loading-area">
      <div class="loading-box"></div>
      <div class="loading-pic">
        <div class="wrapper">
          <div class="cssload-loader"></div>
        </div>
      </div>
    </div>
    <!-- LOADING AREA  END ====== -->

    <div class="page-wraper bg-gradient-to-br">
      <!-- CONTENT START -->
      <div class="page-content">
        <!-- Register Section Start -->
        <div class="section-full site-bg-white">
          <div class="container-fluid">
            <div class="row">
              <div class="col-xl-8 col-lg-6 col-md-5 twm-log-reg-media-wrap">
                <div class="twm-log-reg-media">
                  <div class="twm-l-media">
                    <img src="/images/reg-bg.png" alt="" />
                  </div>
                </div>
              </div>
              <div class="col-xl-4 col-lg-6 col-md-7">
                <div class="twm-log-reg-form-wrap">
                  <div class="twm-log-reg-logo-head">
                    <a href="/">
                      <img src="/images/logo-light.png" alt="" class="logo" />
                    </a>
                  </div>
                  <div class="twm-log-reg-inner">
                    <div class="twm-log-reg-head">
                      <div class="twm-log-reg-logo">
                        <span class="log-reg-form-title">Register</span>
                      </div>
                    </div>
                    <div class="twm-tabs-style-2">
                      <div class="tab-content" id="myTabContent">
                        <div class="tab-pane fade show active" id="twm-candidate-Signup">
                          <div class="row">
                            <form action="/auth/register" method="POST">
                              <input type="hidden" name="_csrf" value="<%= it.csrfToken %>" />
                              <div class="col-lg-12">
                                <div class="form-group mb-3">
                                  <input name="email" type="email" class="form-control" placeholder="Email*" required />
                                </div>
                              </div>
                              <div class="col-lg-12">
                                <div class="form-group mb-3">
                                  <input name="phone" type="text" class="form-control" placeholder="Phone*" required />
                                </div>
                              </div>
                              <div class="col-lg-12">
                                <div class="form-group mb-3">
                                  <select
                                  class="wt-select-box selectpicker"
                                  name="type"
                                >
                                  <option value="STARTUP">STARTUP</option>
                                  <option value="ENTERPRISE">ENTERPRISE</option>

                                </select>
                                </div>
                              </div>
                              <div class="col-lg-12">
                                <div class="form-group mb-3">
                                  <input
                                    name="password"
                                    type="password"
                                    class="form-control"
                                    placeholder="Password*"
                                    required
                                  />
                                </div>
                              </div>
                              <div class="col-lg-12">
                                <div class="form-group mb-3">
                                  <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="agree1" required />
                                    <label class="form-check-label" for="agree1"
                                      >I agree to the
                                      <a href="javascript:;" class="site-text-primary">Terms and conditions</a></label
                                    >
                                    <p>
                                      Already registered?
                                      <a href="/auth/login" class="twm-backto-login m-l5 site-text-primary"
                                        >Log in here</a
                                      >
                                    </p>
                                  </div>
                                </div>
                              </div>
                              <div class="col-md-12">
                                <div class="form-group">
                                  <button type="submit" class="site-button">Sign Up</button>
                                </div>
                              </div>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- Register Section End -->
      </div>
      <!-- CONTENT END -->

      <%~ include('./partials/footer') %>
      <!-- BUTTON TOP START -->
      <button class="scroltop"><span class="fa fa-angle-up relative" id="btn-vibrate"></span></button>
    </div>

    <%~ include('./partials/scripts') %>
  </body>
</html>
