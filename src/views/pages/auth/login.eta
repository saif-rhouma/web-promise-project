<!DOCTYPE html>
<html lang="en">
<%~ include('./partials/head') %>

<body>
  <!-- LOADING AREA START ===== -->
  <div class="loading-area">
    <div class="loading-box"></div>
    <div class="loading-pic">
      <div class="wrapper">
        <div class="cssload-loader"></div>
      </div>
    </div>
  </div>
  <!-- LOADING AREA END ====== -->

  <div class="page-wraper">
    <div class="page-content">

      <div class="section-full site-bg-white">
        <div class="container-fluid">
          <div class="row">

            <!-- LEFT IMAGE -->
            <div class="col-xl-8 col-lg-6 col-md-5 twm-log-reg-media-wrap">
              <div class="twm-log-reg-media">
                <div class="twm-l-media">
                  <img src="/images/login-bg.png" alt="" />
                </div>
              </div>
            </div>

            <!-- RIGHT FORM -->
            <div class="col-xl-4 col-lg-6 col-md-7">
              <div class="twm-log-reg-form-wrap">

                <div class="twm-log-reg-logo-head">
                  <a href="/">
                    <img src="/images/logo-dark.png" alt="" class="logo" />
                  </a>
                </div>

                <div class="twm-log-reg-inner">

                  <div class="twm-log-reg-head">
                    <span class="log-reg-form-title">Log In</span>
                  </div>

                  <!-- ERROR MESSAGE -->
                  <%~ it.error ? `
  <div style="
    background:#ffe5e5;
    color:#b30000;
    padding:10px;
    margin-bottom:15px;
    border-radius:6px;
    font-weight:500;
  ">
    ${it.error}
  </div>
` : '' %>

                  <!-- FORM -->
                  <form action="/auth/login" method="POST">

                    <!-- CSRF -->
                    <input type="hidden" name="_csrf" value="<%= it.csrfToken  %>" />

                    <!-- EMAIL -->
                    <div class="form-group mb-3">
                      <input
                        name="email"
                        type="email"
                        class="form-control"
                        placeholder="Email*"
                        required
                      />
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group mb-3">
                      <input
                        name="password"
                        type="password"
                        class="form-control"
                        placeholder="Password*"
                        required
                      />
                    </div>

                    <!-- SUBMIT -->
                    <div class="form-group">
                      <button type="submit" class="site-button w-100">
                        Log in
                      </button>
                    </div>

                  </form>

                  <!-- REGISTER LINK -->
                  <div class="mt-3 text-center">
                    <p>
                      Don’t have an account?
                      <a href="/auth/register" class="site-text-primary">
                        Register here
                      </a>
                    </p>
                  </div>

                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>

    <%~ include('./partials/footer') %>

    <button class="scroltop">
      <span class="fa fa-angle-up relative" id="btn-vibrate"></span>
    </button>
  </div>

  <%~ include('./partials/scripts') %>
</body>
</html>