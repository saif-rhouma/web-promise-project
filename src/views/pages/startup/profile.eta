<!DOCTYPE html>
<html lang="en">
  <%~ include('./partials/head') %>

  <body>
    <!-- LOADING AREA START ===== -->
    <div class="loading-area">
      <div class="loading-box"></div>
      <div class="loading-pic">
        <div class="wrapper">
          <div class="cssload-loader"></div>
        </div>
      </div>
    </div>
    <!-- LOADING AREA  END ====== -->

    <div class="page-wraper">
      <!-- CONTENT START -->
      <div class="page-content">
        <%~ include('./partials/startup-inner-banner') %>

        <!-- OUR BLOG START -->
        <div class="section-full p-t120 p-b90 site-bg-white">
          <div class="container">
            <div class="row">
              <%~ include('./partials/startup-sidemenu') %>

              <div class="col-xl-9 col-lg-8 col-md-12 m-b30">
                <!--Filter Short By-->
                <div class="twm-right-section-panel site-bg-gray">
                  <form action="/startup/profile" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf" value="<%= it.csrfToken %>" />
                    <!--Basic Information-->
                    <div class="panel panel-default">
                      <div class="panel-heading wt-panel-heading p-a20">
                        <h4 class="panel-tittle m-a0">Company Profile</h4>
                      </div>
                      <div class="panel-body wt-panel-body p-a20 m-b30">
                        <div class="row">
                          <div class="col-xl-6 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Company Name</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="name"
                                  value="<%= it.startupProfile.name || '' %>"
                                  type="text"
                                  placeholder="Company name"
                                />
                                <i class="fs-input-icon fa fa-building"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-6 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Sector</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="sector"
                                  value="<%= it.startupProfile.sector || '' %>"
                                  list="sectorList"
                                  placeholder="Select or type sector"
                                />

                                <i class="fs-input-icon fa fa-industry"></i>

                                <datalist id="sectorList" class="inner show">
                                  <option value="Technology"></option>
                                  <option value="Finance"></option>
                                  <option value="Healthcare"></option>
                                  <option value="Education"></option>
                                  <option value="E-commerce"></option>
                                  <option value="Manufacturing"></option>
                                  <option value="Logistics"></option>
                                  <option value="Energy"></option>
                                  <option value="Agriculture"></option>
                                  <option value="Real Estate"></option>
                                </datalist>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-6 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Phone</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="phone"
                                  value="<%= it.startupProfile.phone || '' %>"
                                  type="text"
                                  placeholder="Phone number"
                                />
                                <i class="fs-input-icon fa fa-phone-alt"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-6 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Email Address</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="email"
                                  value="<%= it.startupProfile.email || '' %>"
                                  type="email"
                                  placeholder="Email"
                                />
                                <i class="fs-input-icon fas fa-at"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-12 col-lg-12 col-md-12">
                            <div class="form-group">
                              <label>Website</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="website"
                                  type="text"
                                  value="<%= it.startupProfile.website || '' %>"
                                  placeholder="https://example.com"
                                />
                                <i class="fs-input-icon fa fa-globe-americas"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-12 col-lg-12 col-md-12">
                            <div class="form-group city-outer-bx has-feedback">
                              <label>Full Address</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control"
                                  name="adress"
                                  value="<%= it.startupProfile.adress || '' %>"
                                  type="text"
                                  placeholder="Full address"
                                />
                                <i class="fs-input-icon fas fa-map-marker-alt"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-12 col-lg-12 col-md-12">
                            <div class="form-group">
                              <label>Image Cover</label>
                              <div class="ls-inputicon-box">
                                <input class="form-control" name="cover" type="file" />
                                <i class="fs-input-icon fa fa-globe-americas"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-md-12">
                            <div class="form-group">
                              <label>Description</label>
                              <textarea class="form-control" name="description" rows="3">
<%= it.startupProfile.description || '' %></textarea
                              >
                            </div>
                          </div>

                          <div class="col-lg-12 col-md-12">
                            <div class="text-left">
                              <button type="submit" class="site-button">Save Changes</button>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!--Social Network-->
                    <div class="panel panel-default">
                      <div class="panel-heading wt-panel-heading p-a20">
                        <h4 class="panel-tittle m-a0">Social Network</h4>
                      </div>
                      <div class="panel-body wt-panel-body p-a20">
                        <div class="row">
                          <div class="col-xl-4 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Facebook</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control wt-form-control"
                                  name="socialLinks[facebook]"
                                  value="<%= it.startupProfile.socialLinks?.facebook || '' %>"
                                  type="text"
                                  placeholder="https://www.facebook.com/"
                                />
                                <i class="fs-input-icon fab fa-facebook-f"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-4 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>linkedin</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control wt-form-control"
                                  name="socialLinks[linkedin]"
                                  value="<%= it.startupProfile.socialLinks?.linkedin || '' %>"
                                  type="text"
                                  placeholder="https://in.linkedin.com/"
                                />
                                <i class="fs-input-icon fab fa-linkedin-in"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-xl-4 col-lg-6 col-md-12">
                            <div class="form-group">
                              <label>Youtube</label>
                              <div class="ls-inputicon-box">
                                <input
                                  class="form-control wt-form-control"
                                  name="socialLinks[youtube]"
                                  value="<%= it.startupProfile.socialLinks?.youtube || '' %>"
                                  type="text"
                                  placeholder="https://www.youtube.com/"
                                />
                                <i class="fs-input-icon fab fa-youtube"></i>
                              </div>
                            </div>
                          </div>

                          <div class="col-lg-12 col-md-12">
                            <div class="text-left">
                              <button type="submit" class="site-button">Save Changes</button>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- OUR BLOG END -->
      </div>
      <!-- CONTENT END -->

      <%~ include('./partials/footer') %>
      <!-- BUTTON TOP START -->
      <button class="scroltop"><span class="fa fa-angle-up relative" id="btn-vibrate"></span></button>
    </div>

    <%~ include('./partials/scripts') %>
  </body>
</html>
