<!DOCTYPE html>
<html lang="en">
<%~ include('./partials/head') %>

  <body>
    <!-- LOADING AREA START ===== -->
    <div class="loading-area">
      <div class="loading-box"></div>
      <div class="loading-pic">
        <div class="wrapper">
          <div class="cssload-loader"></div>
        </div>
      </div>
    </div>
    <!-- LOADING AREA  END ====== -->

    <div class="page-wraper">
      <!-- CONTENT START -->
      <div class="page-content">
        <%~ include('./partials/startup-inner-banner') %>

          <!-- OUR BLOG START -->
          <div class="section-full p-t120 p-b90 site-bg-white">
            <div class="container">
              <div class="row">
                <%~ include('./partials/startup-sidemenu') %>

                  <div class="col-xl-9 col-lg-8 col-md-12 m-b30">

                    <div class="twm-right-section-panel site-bg-gray">

                      <div class="wt-admin-dashboard-msg-2 twm-dashboard-style-2">

                        <!-- LEFT SIDEBAR -->
                        <div class="wt-dashboard-msg-user-list">

                          <!-- SEARCH -->
                          <div class="wt-dashboard-msg-search">
                            <div class="input-group">

                              <input class="form-control" placeholder="Search Messages" type="text"
                                id="conversationSearch">

                              <button class="btn" type="button">
                                <i class="fa fa-search"></i>
                              </button>

                            </div>
                          </div>

                          <!-- LIST -->
                          <div id="msg-list-wrap" class="wt-dashboard-msg-search-list scrollbar-macosx">

                            <% it.receivedContacts.forEach(c=> { %>

                              <% const active=it.startup && it.startup.id===c.startup.id; %>

                                <div class="wt-dashboard-msg-search-list-wrap conversation-item"
                                  data-name="<%= c.startup.name.toLowerCase() %>"
                                  data-message="<%= c.lastMessage.message.toLowerCase() %>">


                                  <a href="#" data-id="<%= c.startup.id %>"
                                    class="msg-user-info clearfix <%= active ? 'active' : '' %> conversation-link">
                                    <div class="msg-user-timing">

                                      <%= new Date(c.lastMessage.createdAt) .toLocaleDateString() %>

                                    </div>

                                    <div class="msg-user-info-pic">

                                      <img src="<%= c.startup.avatar
            ? '/images/' + c.startup.avatar
            : '/images/default-cover.jpg' %>" alt="avatar">

                                    </div>

                                    <div class="msg-user-info-text">

                                      <div class="msg-user-name d-flex align-items-center">

                                        <%= c.startup.name %>

                                          <% if (c.unreadCount> 0) { %>

                                            <span class="conversation-unread-badge">
                                              <%= c.unreadCount %>
                                            </span>

                                            <% } %>

                                      </div>

                                      <div class="msg-user-discription">

                                        <%= c.lastMessage.message.substring(0, 40) %>

                                      </div>

                                    </div>

                                  </a>

                                </div>

                                <% }) %>

                          </div>

                        </div>

                        <!-- RIGHT CHAT -->
                        <!-- RIGHT CHAT -->
                        <div class="wt-dashboard-msg-box">

                          <!-- HEADER -->
                          <% if (it.startup) { %>

                            <div class="single-msg-user-name-box">

                              <div class="twm-DT-candidates-list">

                                <div class="twm-media">
                                  <div class="twm-media-pic">
                                    <img src="<%= it.startup.avatar 
              ? '/images/' + it.startup.avatar
              : '/images/default-cover.jpg' %>" />
                                  </div>
                                </div>

                                <div class="twm-mid-content">
                                  <h4>
                                    <%= it.startup.name %>
                                  </h4>

                                  <p class="twm-candidate-address">
                                    <i class="feather-map-pin"></i>
                                    <%= it.startup.adress || '' %>
                                  </p>
                                </div>

                              </div>

                            </div>

                            <% } %>


                              <!-- CHAT AREA (ALWAYS EXISTS) -->
                              <div id="msg-chat-wrap" class="single-user-msg-conversation scrollbar-macosx"
                                data-user-id="<%= it.user.startupProfile.id %>" data-user-avatar="<%= it.startupProfile.avatar 
      ? '/images/' + it.startupProfile.avatar 
      : '/images/jobs-company/pic1.jpg' %>">

                                <% if (it.startup && it.conversations.length) { %>

                                  <% it.conversations.forEach(message=> { %>

                                    <% const isMine=message.sender.id===it.user.startupProfile.id; %>

                                      <div class="single-user-comment-wrap <%= isMine ? 'sigle-user-reply' : '' %>">

                                        <div class="row <%= isMine ? 'justify-content-end' : '' %>">

                                          <div class="col-xl-9 col-lg-12">

                                            <div class="single-user-comment-block clearfix">

                                              <div class="single-user-com-pic">
                                                <img src="<%= message.sender.avatar 
                    ? '/images/' + message.sender.avatar
                    : '/images/default-cover.jpg' %>">
                                              </div>

                                              <div class="single-user-com-text">
                                                <%= message.message %>
                                              </div>

                                              <div class="single-user-msg-time">
                                                <%= new Date(message.createdAt).toLocaleTimeString([], { hour: '2-digit'
                                                  , minute: '2-digit' }) %>
                                              </div>

                                            </div>

                                          </div>

                                        </div>

                                      </div>

                                      <% }) %>

                                        <% } else { %>

                                          <div
                                            class="h-100 d-flex align-items-center justify-content-center p-5 text-muted">
                                            <div class="text-center">
                                              <i class="fa fa-comments fa-4x mb-3"></i>
                                              <h5>No messages yet</h5>
                                            </div>
                                          </div>

                                          <% } %>

                              </div>


                              <!-- ALWAYS RENDER FORM (but disabled state if no startup) -->
                              <div class="single-msg-reply-comment">

                                <form id="conversationForm">

                                  <input type="hidden" name="_csrf" value="<%= it.csrfToken %>">

                                  <input type="hidden" name="receiverId" value="<%= it.startup ? it.startup.id : '' %>">

                                  <input type="hidden" name="subject" value="Startup Contact">

                                  <div class="input-group">

                                    <textarea
  id="messageInput"
  class="form-control"
  name="message"
  placeholder="<%= it.startup ? 'Type a message here' : 'Select a conversation first' %>"
  <%= it.startup ? '' : 'disabled' %>
  required
></textarea>

                                    <button class="btn" type="submit" <%=it.startup ? '' : 'disabled' %>
                                      >
                                      <i class="fa fa-paper-plane"></i>
                                    </button>

                                  </div>

                                </form>

                              </div>

                        </div>

                      </div>

                    </div>

                  </div>
              </div>
            </div>
            <!-- OUR BLOG END -->
          </div>
          <!-- CONTENT END -->

          <%~ include('./partials/scripts') %>
            <div id="conversation-data"
              data-user-avatar="<%= it.startupProfile.avatar ? '/images/' + it.startupProfile.avatar : '/images/jobs-company/pic1.jpg' %>"
              data-user-id="<%= it.user.startupProfile.id %>">
            </div>

            <script src="/js/messages.js"></script>

  </body>

</html>