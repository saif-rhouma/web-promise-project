<!DOCTYPE html>
<html lang="en">
<%~ include('./partials/head') %>

  <body>
    <!-- LOADING AREA START ===== -->
    <div class="loading-area">
      <div class="loading-box"></div>
      <div class="loading-pic">
        <div class="wrapper">
          <div class="cssload-loader"></div>
        </div>
      </div>
    </div>
    <!-- LOADING AREA  END ====== -->

    <div class="page-wraper">
      <!-- CONTENT START -->
      <div class="page-content">
        <%~ include('./partials/startup-inner-banner') %>

          <!-- OUR BLOG START -->
          <div class="section-full p-t120 p-b90 site-bg-white">
            <div class="container">
              <div class="row">
                <%~ include('./partials/startup-sidemenu') %>

                  <div class="col-xl-9 col-lg-8 col-md-12 m-b30">
                    <!--Filter Short By-->
                    <% if (it.job) { %>
                      <div class="twm-jobs-list-style1 mb-5">
                        <div class="twm-media">
                          <img src="/images/<%= it.job.cover %>" alt="#">
                        </div>
                        <div class="twm-mid-content">

                          <h4>
                            <%= it.job.title %></span>
                          </h4>

                          <p class="twm-job-address">
                            <%= it.job.category %>
                          </p>

                        </div>
                        <div class="twm-right-content">
                          <% if( it.job.period) {%>
                            <div class="twm-jobs-category green"><span class="twm-bg-green">
                                <%= it.job.period %>
                              </span></div>
                            <% } %>
                              <div class="twm-jobs-amount">
                                <%= new Date(it.job.createdAt).toLocaleDateString('en-GB') %><span></span>
                              </div>
                              <span class="twm-jobs-browse site-text-primary"></span>
                        </div>
                      </div>
                      <% } %>
                        <div class="twm-right-section-panel candidate-save-job site-bg-gray">
                          <div class="twm-D_table table-responsive">
                            <table id="jobs_bookmark_table"
                              class="table table-bordered twm-candidate-save-job-list-wrap">
                              <thead>
                                <tr>
                                  <th>Full name</th>
                                  <th>Job Title</th>
                                  <th>Applied Date</th>
                                  <th>Status</th>
                                  <th>Action</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% it.applications.forEach(application=> { %>
                                  <tr>
                                    <td>
                                      <div class="twm-mid-content">
                                        <h4>
                                          <%= application.fullName %>
                                        </h4>
                                      </div>
                                    </td>

                                    <td>
                                      <%= application.jobPost?.title %>
                                    </td>

                                    <td>
                                      <%= new Date(application.appliedAt).toLocaleDateString() %>
                                    </td>
                                    <td>
                                      <div class="twm-jobs-category">
                                        <% const statusColors={ 'ACCEPTED' : 'twm-bg-green' , 'REVIEWED' : 'twm-bg-sky'
                                          , 'PENDING' : 'twm-bg-golden' , 'REJECTED' : 'twm-bg-red' }; %>

                                          <span class="<%= statusColors[application?.status] || 'text-clr-default' %>">
                                            <%= application?.status || 'N/A' %>
                                          </span>

                                      </div>
                                    </td>
                                    <td>
                                      <div class="twm-table-controls">
                          
                                        <ul class="twm-DT-controls-icon list-unstyled d-flex gap-2">
                                          <li>
                                            <a href="/startup/applications/<%= application.id %>/cv" download
                                              title="Download CV">
                                              <span class="fa fa-download"></span>
                                            </a>
                                          </li>
                                          <li>

                                            <select class="application-status" data-id="<%= application.id %>">
                                              <option value="PENDING" <%=application.status==='PENDING' ? 'selected'
                                                : '' %>>Pending</option>
                                              <option value="REVIEWED" <%=application.status==='REVIEWED' ? 'selected'
                                                : '' %>>Reviewed</option>
                                              <option value="ACCEPTED" <%=application.status==='ACCEPTED' ? 'selected'
                                                : '' %>>Accepted</option>
                                              <option value="REJECTED" <%=application.status==='REJECTED' ? 'selected'
                                                : '' %>>Rejected</option>
                                            </select>
                                          </li>

                                        </ul>
                                      </div>
                                    </td>
                                  </tr>
                                  <% }) %>
                              </tbody>
                              <tfoot>
                                <tr>
                                  <th>Full name</th>
                                  <th>Job Title</th>
                                  <th>Date</th>
                                  <th>Status</th>
                                  <th>Action</th>
                                </tr>
                              </tfoot>
                            </table>
                          </div>
                        </div>
                  </div>
              </div>
            </div>
          </div>
          <!-- OUR BLOG END -->
      </div>
      <!-- CONTENT END -->

      <%~ include('./partials/footer') %>
        <!-- BUTTON TOP START -->
        <button class="scroltop"><span class="fa fa-angle-up relative" id="btn-vibrate"></span></button>
    </div>
    <%~ include('./partials/scripts') %>
  </body>

</html>