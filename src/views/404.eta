<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Page Not Found</title>

    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
          Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        background: #0f172a;
        color: #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
      }

      .container {
        text-align: center;
        max-width: 500px;
      }

      h1 {
        font-size: 6rem;
        margin: 0;
        color: #38bdf8;
      }

      h2 {
        margin: 10px 0;
        font-weight: 500;
      }

      p {
        color: #94a3b8;
        margin-bottom: 30px;
      }

      a {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 8px;
        background: #38bdf8;
        color: #0f172a;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s ease;
      }

      a:hover {
        background: #0ea5e9;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <h2>Page Not Found</h2>
      <p>
        Sorry, the page you are looking for doesn’t exist or has been moved.
      </p>
      <a href="/">Go Back Home</a>
    </div>
  </body>
</html>