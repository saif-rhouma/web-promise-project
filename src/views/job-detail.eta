<!DOCTYPE html>
<html lang="en">
  <%~ include('./partials/head') %>

  <body>
    <!-- LOADING AREA START ===== -->
    <div class="loading-area">
      <div class="loading-box"></div>
      <div class="loading-pic">
        <div class="wrapper">
          <div class="cssload-loader"></div>
        </div>
      </div>
    </div>
    <!-- LOADING AREA  END ====== -->

    <div class="page-wraper">
      <%~ include('./partials/header') %>
      <!-- CONTENT START -->
      <div class="page-content">
        <!-- OUR BLOG START -->
        <div class="section-full p-t60 p-b90 bg-white">
          <div class="container">
            <!-- BLOG SECTION START -->
            <div class="section-content">
              <div class="row d-flex justify-content-center">
                <div class="col-lg-8 col-md-12">
                  <!-- Candidate detail START -->
                  <div class="cabdidate-de-info">
                    <div
                      class="twm-candi-self-wrap overlay-wraper"
                      style="background-image: url(<%=it.job.cover||'/images/candidates/candidate-bg.jpg'%>)"
                    >
                      <div class="overlay-main site-bg-primary opacity-01"></div>
                      <div class="twm-candi-self-info">
                        <div class="twm-candi-self-top">
                          <div class="twm-media">
                            <img src="<%= it.job.startup.avatar || '/images/default-cover.jpg' %>" alt="cover" />
                          </div>
                          <div class="twm-mid-content">
                            <h4 class="twm-job-title"><%=it.job.startup.name %></h4>

                            <p class="twm-candidate-address">
                              <i class="feather-map-pin"></i><%=it.job.startup.adress %>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <h4 class="twm-s-title"><%=it.job.title %></h4>

                    <p><%=it.job.description %></p>

                    <h4 class="twm-s-title">Roles et Responsabilités</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.roles %></div>
                      </div>
                    </div>

                    <h4 class="twm-s-title">Ce que nous vous offrons</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.offers %></div>
                      </div>
                    </div>

                    <h4 class="twm-s-title">Connaissances</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.knowledge %></div>
                      </div>
                    </div>

                    <h4 class="twm-s-title">Soft skills</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.softSkills %></div>
                      </div>
                    </div>

                    <h4 class="twm-s-title">Outils (par ordre d’importance)</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.tools %></div>
                      </div>
                    </div>

                    <h4 class="twm-s-title">Expérience préférée</h4>
                    <div class="twm-timing-list-wrap">
                      <div class="twm-timing-list">
                        <div class="twm-time-list-discription"><%~it.job.tools %></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="col-lg-4 col-md-12 rightSidebar">
                  <div class="side-bar-2">
                    <div class="twm-s-info-wrap mb-5">
                      <div class="twm-s-info">
                        <ul>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-clock"></i>
                              <span class="twm-title">Durée</span>
                              <div class="twm-s-info-discription"><%=it.job.period %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-user-edit"></i>
                              <span class="twm-title">Experience</span>
                              <div class="twm-s-info-discription"><%=it.job.experience %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-venus-mars"></i>
                              <span class="twm-title">Gender</span>
                              <div class="twm-s-info-discription"><%=it.job.gender %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-mobile-alt"></i>
                              <span class="twm-title">Phone</span>
                              <div class="twm-s-info-discription"><%=it.job.startup.phone %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-at"></i>
                              <span class="twm-title">Email</span>
                              <div class="twm-s-info-discription"><%=it.job.startup.email %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-book-reader"></i>
                              <span class="twm-title">Qualification</span>
                              <div class="twm-s-info-discription"><%=it.job.qualification %></div>
                            </div>
                          </li>

                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-language"></i>
                              <span class="twm-title">Langues</span>
                              <div class="twm-s-info-discription"><%=it.job.languages %></div>
                            </div>
                          </li>
                          <li>
                            <div class="twm-s-info-inner">
                              <i class="fas fa-map-marker-alt"></i>
                              <span class="twm-title">Address</span>
                              <div class="twm-s-info-discription"><%=it.job.location %></div>
                            </div>
                          </li>
                        </ul>
                      </div>
                    </div>

                    <div class="twm-s-contact-wrap mb-5">
                      <h4 class="section-head-small mb-4">Contact us</h4>
                      <form action="/applications/<%= it.job.id %>" method="POST" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= it.csrfToken %>" />
                        <div class="twm-s-contact">
                          <div class="row">
                            <div class="col-lg-12">
                              <div class="form-group mb-3">
                                <input name="fullName" type="text" required class="form-control" placeholder="Name" />
                              </div>
                            </div>

                            <div class="col-lg-12">
                              <div class="form-group mb-3">
                                <input name="email" type="text" class="form-control" required placeholder="Email" />
                              </div>
                            </div>

                            <div class="col-lg-12">
                              <div class="form-group mb-3">
                                <input name="phone" type="text" class="form-control" required placeholder="Phone" />
                              </div>
                            </div>

                            <div class="col-lg-12">
                              <div class="form-group mb-3">
                                <textarea name="message" class="form-control" rows="3" placeholder="Message"></textarea>
                              </div>
                            </div>

                            <div class="col-lg-12">
                              <div class="form-group mb-3">
                                <label>Upload Resume</label>
                                <div class="ls-inputicon-box">
                                  <input class="form-control" name="cv" type="file" required />
                                  <i class="fs-input-icon fa fa-globe-americas"></i>
                                </div>
                              </div>
                            </div>

                            <div class="col-md-12">
                              <button type="submit" class="site-button">Submit Now</button>
                            </div>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- OUR BLOG END -->
      </div>
      <!-- CONTENT END -->

      <%~ include('./partials/footer') %>
      <!-- BUTTON TOP START -->
      <button class="scroltop"><span class="fa fa-angle-up relative" id="btn-vibrate"></span></button>
      <%~ include('./partials/modals') %>
    </div>

    <%~ include('./partials/scripts') %>
  </body>
</html>
